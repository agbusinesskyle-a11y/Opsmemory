# OpsMemory API — environment contract
#
# Copy this to `.env` on Spark and fill production values. Never commit `.env`.
# `.env.example` is committed so deploy knows what variables are required.

# --- Runtime ---
ENVIRONMENT=production
APP_VERSION=chunk1
LOG_LEVEL=INFO

# --- Auth ---
# AUTH_MODE=cloudflare for production (validates Cf-Access-Jwt-Assertion).
# AUTH_MODE=local for dev (skips JWT verify, uses LOCAL_DEV_EMAIL).
AUTH_MODE=cloudflare

# Filled in when the Cloudflare Access app for tracker.kyleconway.ai is created.
# Team domain example: https://kyleconway.cloudflareaccess.com
CF_ACCESS_TEAM_DOMAIN=https://<team>.cloudflareaccess.com
CF_ACCESS_AUD=<your-access-app-aud-tag>

# Used only when AUTH_MODE=local. No default — set explicitly in dev environments.
# Must match an existing email in the users table (or the dev user lookup will 403).
LOCAL_DEV_EMAIL=
ALLOW_DEV_USER_SWITCH=false

# Pepper for HMAC-SHA256 of service-account API keys.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SERVICE_KEY_PEPPER=<generate-32-byte-random>

# --- Database ---
# Runtime app role (cannot DROP). Created during deploy.
DATABASE_URL=postgresql://opsmemory_app:<password>@postgres:5432/action_tracker
DB_POOL_MIN=1
DB_POOL_MAX=10
DB_STATEMENT_TIMEOUT_MS=30000
DB_IDLE_IN_TRANSACTION_TIMEOUT_MS=30000

# --- Web ---
WEB_ROOT=/app/web

# --- Health / readiness ---
# Set to true after first successful backup so /readyz checks backup freshness.
# Keep false during initial deploy to avoid bootstrapping failure.
READYZ_REQUIRE_BACKUP=false
READYZ_BACKUP_MAX_AGE_HOURS=36
READYZ_RESTORE_MAX_AGE_HOURS=192

# Status JSON files written by backup/restore scripts, read by /readyz.
BACKUP_STATUS_FILE=/var/lib/opsmemory/backup/status.json
RESTORE_STATUS_FILE=/var/lib/opsmemory/backup/restore_status.json

# --- Backup script (consumed by scripts/backup_action_tracker.ps1) ---
# pg_dump runs INSIDE the postgres container via docker exec (Unix-socket
# peer auth, no password needed). Override defaults only if your container
# name or role names differ from the standard chunk1 deploy.
POSTGRES_CONTAINER=postgres
ACTION_TRACKER_DB_ROLE=opsmemory_owner
ACTION_TRACKER_DB_NAME=action_tracker
BACKUP_ROOT=/var/backups/opsmemory/action_tracker
BACKUP_RETENTION_DAYS=14
# Optional Spark #2 rsync target. Empty = local-only backup.
BACKUP_SPARK2_TARGET=opsbackup@spark2:/srv/backups/opsmemory/action_tracker/
# Optional webhook called on backup or restore-check failure
# (e.g. existing n8n alert webhook).
BACKUP_ALERT_WEBHOOK_URL=

# --- Restore-check script (scripts/restore_check.ps1) ---
# psql runs inside the postgres container as the existing superuser via
# docker exec. Override defaults only if your container superuser name
# differs from the chunk1 deploy.
RESTORE_TEST_ADMIN_USER=openbrain
RESTORE_TEST_ADMIN_DB=openbrain
RESTORE_TEST_DB=action_tracker_restore_test
KEEP_RESTORE_DB=false

# --- Network ---
# Existing Docker network on Spark that hosts Postgres + n8n + mcp-server.
# Adjust if the existing network is named differently.
SPARK_NETWORK_NAME=spark_internal

# --- Deferred to Chunk 1.5 ---
# GPG_RECIPIENT=
# B2_BUCKET=
# B2_KEY_ID=
# B2_APPLICATION_KEY=
