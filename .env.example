# OpsMemory API — environment contract
#
# Copy this to `.env` on Spark and fill production values. Never commit `.env`.
# `.env.example` is committed so deploy knows what variables are required.

# --- Runtime ---
ENVIRONMENT=production
APP_VERSION=chunk1
LOG_LEVEL=INFO

# --- Auth ---
# AUTH_MODE=cloudflare for production (validates Cf-Access-Jwt-Assertion).
# AUTH_MODE=local for dev (skips JWT verify, uses LOCAL_DEV_EMAIL).
AUTH_MODE=cloudflare

# Filled in when the Cloudflare Access app for tracker.kyleconway.ai is created.
# Team domain example: https://kyleconway.cloudflareaccess.com
CF_ACCESS_TEAM_DOMAIN=https://<team>.cloudflareaccess.com
CF_ACCESS_AUD=<your-access-app-aud-tag>

# Used only when AUTH_MODE=local. No default — set explicitly in dev environments.
# Must match an existing email in the users table (or the dev user lookup will 403).
LOCAL_DEV_EMAIL=
ALLOW_DEV_USER_SWITCH=false

# Pepper for HMAC-SHA256 of service-account API keys.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
#
# Pepper rotation (Chunk 1.5+): use versioned envs instead of the legacy
# single-pepper scheme. Set SERVICE_KEY_PEPPER_ACTIVE_VERSION to the
# version that NEW keys should be hashed with; existing keys continue
# verifying against whichever version they were originally hashed with
# (recorded in service_accounts.metadata.pepper_version).
#
#   SERVICE_KEY_PEPPER_ACTIVE_VERSION=V1
#   SERVICE_KEY_PEPPER_V1=<32-byte-random>
#   SERVICE_KEY_PEPPER_V2=<next-pepper-during-rotation>
#
# Legacy SERVICE_KEY_PEPPER (below) is still honored — empty pepper_version
# in service_accounts maps to it. Migrate to versioned format when ready.
SERVICE_KEY_PEPPER=<generate-32-byte-random>

# --- Database ---
# Runtime app role (cannot DROP). Created during deploy.
DATABASE_URL=postgresql://opsmemory_app:<password>@postgres:5432/action_tracker
DB_POOL_MIN=1
DB_POOL_MAX=10
DB_STATEMENT_TIMEOUT_MS=30000
DB_IDLE_IN_TRANSACTION_TIMEOUT_MS=30000

# --- Web ---
WEB_ROOT=/app/web

# --- Health / readiness ---
# Set to true after first successful backup so /readyz checks backup freshness.
# Keep false during initial deploy to avoid bootstrapping failure.
READYZ_REQUIRE_BACKUP=false
READYZ_BACKUP_MAX_AGE_HOURS=36

# Set to true after the weekly restore-check timer has fired at least once,
# so /readyz catches a long-broken restore loop. Default false so an
# unbacked-up Spark can still boot.
READYZ_REQUIRE_RESTORE=false
READYZ_RESTORE_MAX_AGE_HOURS=192

# Status JSON files written by backup/restore scripts, read by /readyz.
BACKUP_STATUS_FILE=/var/lib/opsmemory/backup/status.json
RESTORE_STATUS_FILE=/var/lib/opsmemory/backup/restore_status.json

# --- Backup script (consumed by scripts/backup_action_tracker.ps1) ---
# pg_dump runs INSIDE the postgres container via docker exec (Unix-socket
# peer auth, no password needed). Override defaults only if your container
# name or role names differ from the standard chunk1 deploy.
POSTGRES_CONTAINER=postgres
ACTION_TRACKER_DB_ROLE=opsmemory_owner
ACTION_TRACKER_DB_NAME=action_tracker
BACKUP_ROOT=/var/backups/opsmemory/action_tracker
BACKUP_RETENTION_DAYS=14
# Optional Spark #2 rsync target. Empty = local-only backup.
BACKUP_SPARK2_TARGET=opsbackup@spark2:/srv/backups/opsmemory/action_tracker/
# Optional webhook called on backup or restore-check failure
# (e.g. existing n8n alert webhook).
BACKUP_ALERT_WEBHOOK_URL=

# --- Restore-check script (scripts/restore_check.ps1) ---
# psql runs inside the postgres container as the existing superuser via
# docker exec. Override defaults only if your container superuser name
# differs from the chunk1 deploy.
RESTORE_TEST_ADMIN_USER=openbrain
RESTORE_TEST_ADMIN_DB=openbrain
RESTORE_TEST_DB=action_tracker_restore_test
KEEP_RESTORE_DB=false

# --- Network ---
# Existing Docker network on Spark that hosts Postgres + n8n + mcp-server.
# Adjust if the existing network is named differently.
SPARK_NETWORK_NAME=spark_internal

# --- GPG encryption (Chunk 1.5 step 5) ---
# Set GPG_ENABLED=true after running scripts/gpg_init.sh and committing
# the public key to infra/keys/backup-public.asc. The recipient identity
# must match the keypair generated by gpg_init.sh.
GPG_ENABLED=false
BACKUP_GPG_RECIPIENT=opsmemory-backup@kyleconway.ai
# Override only if the public key lives elsewhere on Spark:
BACKUP_GPG_PUBLIC_KEY_FILE=/opt/opsmemory/infra/keys/backup-public.asc

# --- LLM / ingest pipeline (Chunk 3) ---
# litellm proxy already runs on Spark for the existing Conway stack.
# OpsMemory's reconciliation pipeline calls it via OpenAI-compatible API.
LITELLM_BASE_URL=http://litellm:4000/v1
LITELLM_API_KEY=<set-from-existing-litellm-deploy>

# Ordered model fallback chains. Try left-to-right; on failure (5xx,
# rate limit, timeout) move to next. Per chunk1 design: local Llama is
# extract/summarize ONLY; never used at the choose step.
INGEST_LLM_EXTRACT_MODELS=claude-sonnet-4-6,gpt-4.1,llama-3.1-70b
INGEST_LLM_CHOOSE_MODELS=claude-sonnet-4-6,gpt-4.1
# Hard daily $ ceiling (USD). Pipeline pauses when projected daily spend
# would exceed this. Slack alert fires.
INGEST_LLM_DAILY_USD_CAP=20

# --- Backblaze B2 offsite (Chunk 1.5 step 6) ---
# Set B2_ENABLED=true after creating a B2 account, bucket, and a
# bucket-scoped Application Key. Until then, backups stay 2-of-3
# (local + Spark #2 only).
#
# Operator setup: see docs/08-b2-setup.md
B2_ENABLED=false
B2_BUCKET=
B2_KEY_ID=
B2_APPLICATION_KEY=

# --- Notifications: Web Push (Chunk 10 step 5) ---
# Generate via:
#   python -c "from py_vapid import Vapid; v = Vapid(); v.generate_keys(); print(v.public_key); print(v.private_key)"
# (or pywebpush's vapid CLI). Subject must be mailto: or https://.
# Leave all three unset to disable Web Push cleanly (the API
# /vapid_public endpoint returns 503 and the Settings UI shows
# 'not configured'). Partially set vars FAIL the API on boot.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=

# --- Notifications: Slack DM digest (Chunk 10 step 6) ---
# n8n webhook URL that fans out to Slack chat.postMessage.
# n8n owns the Slack app credentials; OpsMemory only POSTs the
# rendered digest body and lets n8n do users.lookupByEmail.
# Bearer is optional but recommended (defense in depth on top
# of Cloudflare Access).
N8N_NOTIFICATION_WEBHOOK_URL=
N8N_NOTIFICATION_WEBHOOK_BEARER=

# --- Weekly Gmail digest drafts (Chunk 11) ---
# n8n webhook URL that fans out to Gmail drafts.create on a
# designated mailbox (per docs/01-design.md: drafts only, never
# auto-sends). The OpsMemory API never holds Gmail credentials;
# n8n owns them. Bearer is optional but recommended (defense in
# depth on top of Cloudflare Access).
N8N_GMAIL_DIGEST_WEBHOOK_URL=
N8N_GMAIL_DIGEST_WEBHOOK_BEARER=
# Default tz for week-boundary computation when a business has
# no per-business tz override (defaults to America/Phoenix).
WEEKLY_DIGEST_DEFAULT_TZ=America/Phoenix
# Days a task can be open past due before it counts as "stale"
# in the weekly digest. Defaults to 14.
WEEKLY_DIGEST_STALE_DAYS=14
